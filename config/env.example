OPENAI_API_KEY=xxx
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro
OPENAI_TIMEOUT_MS=600000
OPENAI_STREAM=true
MINIMAX_API_KEY=xxx
MINIMAX_GROUP_ID=xxx
PORT=3000
AUTO_CONFIRM=false
RENDER_FPS=30

# Rendering engine: "remotion" (default) or "puppeteer"
RENDER_ENGINE=remotion

# Whisper STT for subtitles: "local" (whisper.cpp) or "api" (OpenAI Whisper)
WHISPER_MODE=api
WHISPER_API_KEY=xxx
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=zh

# Stock image APIs
PEXELS_API_KEY=xxx
UNSPLASH_API_KEY=xxx

# Background music
BGM_PATH=assets/bgm.mp3
BGM_VOLUME=0.15
